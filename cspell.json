{
    "version": "0.2",
    "language": "en-US",
    "ignorePaths": [
        "node_modules/**",
        ".next/**",
        "k8s/**",
        ".idea/**",
        ".vscode/**",
        ".git/**",
        ".github/**",
        "**/*.svg",
        "**/*.xml",
        "Dockerfile",
        "package.json",
        "package-lock.json",
        "tsconfig.json",
        "dist/**",
        "*.spec.ts",
        "src/test/*"
    ],
    "ignoreWords": [
        "rasmus",
        "readyz",
        "rhaversen",
        "livez",
        "anthropic",
        "openai",
        "prefill",
        "brainwash",
        "brainwashing",
        "underspecified",
        "giveup",
        "oneword",
        "conv",
        "derpy",
        "maxlength"
    ]
}
