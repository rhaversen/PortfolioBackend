{
	"name": "portfolio-backend",
	"type": "module",
	"scripts": {
		"build": "tsc",
		"start": "node \"index.js\"",
		"dev": "(if exist dist rmdir /s /q dist) & tsc && node --env-file .env \"dist/development/index.js\"",
		"test:development": "mocha --reporter spec --recursive \"dist/test/development/**/*.spec.js\"",
		"lint": "npx eslint \"**/*.ts\"",
		"lint:fix": "npx eslint \"**/*.ts\" --fix",
		"spellcheck": "npx cspell ."
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.105.0",
		"config": "^4.4.1",
		"cors": "^2.8.6",
		"express": "^5.2.1",
		"express-rate-limit": "^8.5.2",
		"helmet": "^8.2.0",
		"socket.io": "^4.8.3",
		"winston": "^3.19.0"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^9.0.0",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/config": "^4.4.0",
		"@types/cors": "^2.8.19",
		"@types/eslint": "^9.6.1",
		"@types/express": "^5.0.6",
		"@types/chai": "^5.2.3",
		"@types/mocha": "^10.0.10",
		"@types/node": "^26.0.0",
		"cspell": "^9.0.0",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.5",
		"eslint-import-resolver-typescript": "^4.4.1",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-n": "^17.21.0",
		"eslint-plugin-promise": "^7.2.1",
		"chai": "^6.2.2",
		"mocha": "^11.7.6",
		"typescript": "^6.0.0",
		"typescript-eslint": "^8.35.0"
	}
}
