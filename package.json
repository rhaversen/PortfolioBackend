{
	"name": "portfolio-backend",
	"type": "module",
	"scripts": {
		"build": "tsc",
		"start": "node \"index.js\"",
		"dev": "(if exist dist rmdir /s /q dist) & tsc && node --env-file .env \"dist/development/index.js\"",
		"test:unit": "mocha --reporter spec --recursive \"dist/test/unit/**/*.spec.js\"",
		"test:development": "mocha --reporter spec --recursive \"dist/test/development/**/*.spec.js\"",
		"test:integration": "mocha --reporter spec --recursive \"dist/test/integration/**/*.spec.js\"",
		"lint": "npx eslint \"**/*.ts\"",
		"lint:fix": "npx eslint \"**/*.ts\" --fix",
		"spellcheck": "npx cspell ."
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"overrides": {
		"mongodb": "~6.20.0"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.105.0",
		"bcrypt": "^6.0.0",
		"config": "^4.4.1",
		"connect-mongo": "^6.0.0",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"express": "^5.2.1",
		"express-rate-limit": "^8.5.2",
		"express-session": "^1.19.0",
		"helmet": "^8.2.0",
		"mongoose": "^9.7.1",
		"nanoid": "^5.1.14",
		"nodemailer": "^7.0.0",
		"passport": "^0.7.0",
		"passport-local": "^1.0.0",
		"socket.io": "^4.8.3",
		"validator": "^13.15.35",
		"winston": "^3.19.0"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^9.0.0",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/bcrypt": "^6.0.0",
		"@types/chai": "^5.2.3",
		"@types/config": "^4.4.0",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.19",
		"@types/eslint": "^9.6.1",
		"@types/express": "^5.0.6",
		"@types/express-session": "^1.19.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^26.0.0",
		"@types/nodemailer": "^7.0.0",
		"@types/passport": "^1.0.17",
		"@types/passport-local": "^1.0.38",
		"@types/sinon": "^21.0.1",
		"@types/validator": "^13.15.10",
		"chai": "^6.2.2",
		"chai-http": "^5.1.2",
		"cspell": "^9.0.0",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.5",
		"eslint-import-resolver-typescript": "^4.4.1",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-n": "^17.21.0",
		"eslint-plugin-promise": "^7.2.1",
		"mocha": "^11.7.6",
		"mongodb-memory-server": "^11.2.0",
		"sinon": "^22.0.0",
		"typescript": "^6.0.0",
		"typescript-eslint": "^8.35.0"
	}
}
