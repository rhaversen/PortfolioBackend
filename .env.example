NODE_ENV=development
SESSION_SECRET=your_session_secret_here

# Database (required in production/staging; optional in dev/test)
DB_NAME=portfolio
DB_USER=portfolio_user
DB_PASSWORD=your_db_password_here
DB_HOST=cluster0.example.mongodb.net

# Email SMTP (required in production/staging; dev/test uses ethereal fallback)
SMTP_SERVER=smtp.example.com
SMTP_LOGIN=no-reply@rhaversen.com
SMTP_KEY=your_email_password_here

# LLM
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Spotify
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_TOKEN_ENCRYPTION_KEY=your_spotify_token_encryption_key_here

# Last.fm
LASTFM_API_KEY=your_lastfm_api_key_here

# ngrok (dev only — optional; enables Spotify OAuth callback via public tunnel)
# Architecture: a persistent Cloud Endpoint (created in the ngrok dashboard) sits
# at NGROK_DOMAIN with a Traffic Policy that uses forward-internal to route to an
# internal Agent Endpoint. On `npm run dev` the server only starts the internal
# agent (NGROK_INTERNAL_DOMAIN), so the public domain is never claimed directly —
# no "already online" conflicts on restart.
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
NGROK_DOMAIN=your-cloud-endpoint-domain.ngrok-free.dev
NGROK_INTERNAL_DOMAIN=default.internal
