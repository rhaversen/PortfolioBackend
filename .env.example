NODE_ENV=development
SESSION_SECRET=your_session_secret_here

# Database (required in production/staging; optional in dev/test)
DB_NAME=portfolio
DB_USER=portfolio_user
DB_PASSWORD=your_db_password_here
DB_HOST=cluster0.example.mongodb.net

# Email SMTP (required in production/staging; dev/test uses ethereal fallback)
SMTP_SERVER=smtp.example.com
SMTP_LOGIN=no-reply@rhaversen.com
SMTP_KEY=your_email_password_here

# LLM
ANTHROPIC_API_KEY=your_anthropic_api_key_here
